# Copy this file to .env and paste your own Anthropic API key.
# Get a key at https://console.anthropic.com
#
# IMPORTANT: no VITE_ prefix on purpose. A VITE_-prefixed variable gets
# baked into the browser bundle at build time, which would leak it to
# every visitor. Without the prefix, this value is only ever readable
# by vite.config.js (Node) in dev, and by api/anthropic/v1/messages.js
# (server) in production — never by client-side code.
ANTHROPIC_API_KEY=sk-ant-your-key-here
